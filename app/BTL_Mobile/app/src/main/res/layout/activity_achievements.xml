<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFB"
    tools:context=".activities.AchievementsActivity">

    <!-- Header Section -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:background="@drawable/bg_orange_gradient"
        android:paddingHorizontal="24dp"
        android:paddingTop="40dp"
        app:layout_constraintTop_toTopOf="parent">

        <FrameLayout
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_soft_button"
            android:padding="4dp"
            android:theme="@style/OrangeButtonTheme"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_soft_inner">
                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_back"
                    app:tint="#FFFFFF"/>
            </FrameLayout>
        </FrameLayout>

        <TextView
            android:id="@+id/txtTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Thành Tích Của Bé 🏆"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/btnBack"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/btnBack" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Thẻ tiến trình -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardProgress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="-15dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="6dp"
        app:layout_constraintTop_toBottomOf="@id/headerLayout">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/txtBadgeProgress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bé đã sưu tập 6 / 12 huy hiệu"
                android:textColor="#333333"
                android:textSize="16sp"
                android:textStyle="bold" />

            <ProgressBar
                android:id="@+id/achievementProgress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="12dp"
                android:layout_marginTop="10dp"
                android:progress="50"
                android:progressDrawable="@drawable/bg_xp_card" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Cố lên bé ơi! Sắp nhận quà rồi! 🎁"
                android:textColor="#FF9800"
                android:textSize="12sp"
                android:textStyle="italic" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Achievement Grid - 1 hàng 3 cột -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:clipToPadding="false"
        android:paddingHorizontal="10dp"
        android:paddingBottom="100dp"
        app:layout_constraintBottom_toTopOf="@id/bottomNavContainer"
        app:layout_constraintTop_toBottomOf="@id/cardProgress">

        <GridLayout
            android:id="@+id/achievementGrid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:alignmentMode="alignMargins"
            android:columnCount="3"
            android:useDefaultMargins="true">

            <!-- 1. Tân Binh -->
            <FrameLayout
                android:id="@+id/achievement1"
                android:layout_width="0dp"
                android:layout_height="165dp"
                android:layout_columnWeight="1"
                android:background="@drawable/bg_soft_button"
                android:theme="@style/GreenButtonTheme"
                android:padding="4dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_soft_inner"
                    android:gravity="center"
                    android:padding="6dp"
                    android:orientation="vertical">
                    <ImageView android:layout_width="38dp" android:layout_height="38dp" android:src="@drawable/ic_star" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="Tân Binh" android:textColor="#FFFFFF" android:textStyle="bold" android:textSize="12sp" android:gravity="center" />
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Hoàn thành bài tập đầu tiên" android:textColor="#E0F2F1" android:textSize="9sp" android:gravity="center" />
                </LinearLayout>
            </FrameLayout>

            <!-- 2. Siêu Tốc -->
            <FrameLayout
                android:id="@+id/achievement2"
                android:layout_width="0dp"
                android:layout_height="165dp"
                android:layout_columnWeight="1"
                android:background="@drawable/bg_soft_button"
                android:theme="@style/BlueButtonTheme"
                android:padding="4dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_soft_inner"
                    android:gravity="center"
                    android:padding="6dp"
                    android:orientation="vertical">
                    <ImageView android:layout_width="38dp" android:layout_height="38dp" android:src="@drawable/ic_trophy" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="Siêu Tốc" android:textColor="#FFFFFF" android:textStyle="bold" android:textSize="12sp" android:gravity="center" />
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Giải bài toán dưới 30 giây" android:textColor="#E3F2FD" android:textSize="9sp" android:gravity="center" />
                </LinearLayout>
            </FrameLayout>

            <!-- 3. Gấu Trúc -->
            <FrameLayout
                android:id="@+id/achievement3"
                android:layout_width="0dp"
                android:layout_height="165dp"
                android:layout_columnWeight="1"
                android:background="@drawable/bg_soft_button"
                android:theme="@style/OrangeButtonTheme"
                android:padding="4dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_soft_inner"
                    android:gravity="center"
                    android:padding="6dp"
                    android:orientation="vertical">
                    <ImageView android:layout_width="42dp" android:layout_height="42dp" android:src="@drawable/panda" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Gấu Trúc" android:textColor="#FFFFFF" android:textStyle="bold" android:textSize="12sp" android:gravity="center" />
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Đạt được 100 điểm đầu" android:textColor="#FFF3E0" android:textSize="9sp" android:gravity="center" />
                </LinearLayout>
            </FrameLayout>

            <!-- 4. Thỏ Con -->
            <FrameLayout
                android:id="@+id/achievement4"
                android:layout_width="0dp"
                android:layout_height="165dp"
                android:layout_columnWeight="1"
                android:background="@drawable/bg_soft_button"
                android:theme="@style/PinkButtonTheme"
                android:padding="4dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_soft_inner"
                    android:gravity="center"
                    android:padding="6dp"
                    android:orientation="vertical">
                    <ImageView android:layout_width="42dp" android:layout_height="42dp" android:src="@drawable/rabbit" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Thỏ Con" android:textColor="#FFFFFF" android:textStyle="bold" android:textSize="12sp" android:gravity="center" />
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Học liên tiếp trong 3 ngày" android:textColor="#FCE4EC" android:textSize="9sp" android:gravity="center" />
                </LinearLayout>
            </FrameLayout>

            <!-- 5. Thông Thái -->
            <FrameLayout
                android:id="@+id/achievement5"
                android:layout_width="0dp"
                android:layout_height="165dp"
                android:layout_columnWeight="1"
                android:background="@drawable/bg_soft_button"
                android:theme="@style/PurpleButtonTheme"
                android:padding="4dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_soft_inner"
                    android:gravity="center"
                    android:padding="6dp"
                    android:orientation="vertical">
                    <ImageView android:layout_width="38dp" android:layout_height="38dp" android:src="@drawable/ic_cup" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="Thông Thái" android:textColor="#FFFFFF" android:textStyle="bold" android:textSize="12sp" android:gravity="center" />
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Đạt 5 bài tập điểm 10" android:textColor="#F3E5F5" android:textSize="9sp" android:gravity="center" />
                </LinearLayout>
            </FrameLayout>

            <!-- 6. Chăm Chỉ -->
            <FrameLayout
                android:id="@+id/achievement6"
                android:layout_width="0dp"
                android:layout_height="165dp"
                android:layout_columnWeight="1"
                android:background="@drawable/bg_soft_button"
                android:theme="@style/GreenButtonTheme"
                android:padding="4dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_soft_inner"
                    android:gravity="center"
                    android:padding="6dp"
                    android:orientation="vertical">
                    <ImageView android:layout_width="38dp" android:layout_height="38dp" android:src="@drawable/ic_book" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="Chăm Chỉ" android:textColor="#FFFFFF" android:textStyle="bold" android:textSize="12sp" android:gravity="center" />
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Hoàn thành 10 bài tập" android:textColor="#E0F2F1" android:textSize="9sp" android:gravity="center" />
                </LinearLayout>
            </FrameLayout>

            <!-- 7. Vô Địch (Locked) -->
            <FrameLayout
                android:id="@+id/achievement7"
                android:layout_width="0dp"
                android:layout_height="165dp"
                android:layout_columnWeight="1"
                android:background="@drawable/bg_soft_button"
                android:theme="@style/GrayButtonTheme"
                android:padding="4dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_soft_inner"
                    android:gravity="center"
                    android:padding="6dp"
                    android:orientation="vertical">
                    <ImageView android:id="@+id/imgBadge7" android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_lock" />
                    <TextView android:id="@+id/txtBadgeTitle7" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Vô Địch" android:textColor="#9E9E9E" android:textStyle="bold" android:textSize="12sp" android:gravity="center" />
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Đạt hạng 1 bảng xếp hạng" android:textColor="#BDBDBD" android:textSize="9sp" android:gravity="center" />
                </LinearLayout>
            </FrameLayout>

            <!-- 8. Kiên Trì (Locked) -->
            <FrameLayout
                android:id="@+id/achievement8"
                android:layout_width="0dp"
                android:layout_height="165dp"
                android:layout_columnWeight="1"
                android:background="@drawable/bg_soft_button"
                android:theme="@style/GrayButtonTheme"
                android:padding="4dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_soft_inner"
                    android:gravity="center"
                    android:padding="6dp"
                    android:orientation="vertical">
                    <ImageView android:id="@+id/imgBadge8" android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_lock" />
                    <TextView android:id="@+id/txtBadgeTitle8" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Kiên Trì" android:textColor="#9E9E9E" android:textStyle="bold" android:textSize="12sp" android:gravity="center" />
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Học bài trong 7 ngày liền" android:textColor="#BDBDBD" android:textSize="9sp" android:gravity="center" />
                </LinearLayout>
            </FrameLayout>

            <!-- 9. Sáng Tạo (Locked) -->
            <FrameLayout
                android:id="@+id/achievement9"
                android:layout_width="0dp"
                android:layout_height="165dp"
                android:layout_columnWeight="1"
                android:background="@drawable/bg_soft_button"
                android:theme="@style/GrayButtonTheme"
                android:padding="4dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_soft_inner"
                    android:gravity="center"
                    android:padding="6dp"
                    android:orientation="vertical">
                    <ImageView android:id="@+id/imgBadge9" android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_lock" />
                    <TextView android:id="@+id/txtBadgeTitle9" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Sáng Tạo" android:textColor="#9E9E9E" android:textStyle="bold" android:textSize="12sp" android:gravity="center" />
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Hoàn thành 5 tranh tô màu" android:textColor="#BDBDBD" android:textSize="9sp" android:gravity="center" />
                </LinearLayout>
            </FrameLayout>

        </GridLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Navigation Bar -->
    <FrameLayout
        android:id="@+id/bottomNavContainer"
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:paddingHorizontal="16dp"
        android:paddingBottom="10dp"
        android:theme="@style/GrayButtonTheme"
        android:background="@android:color/transparent"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/bottomNav"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:layout_gravity="bottom"

            android:padding="6dp"
            android:orientation="horizontal"
            android:gravity="center">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_soft_inner"
                android:orientation="horizontal"
                android:gravity="center">

                <LinearLayout
                    android:id="@+id/navHome"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true">
                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:src="@drawable/ic_home"
                        app:tint="#383838"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Trang chủ"
                        android:textSize="10sp"
                        android:textColor="#000000"
                        android:textStyle="bold"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/navRanking"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true">
                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:src="@drawable/ic_cup"
                        app:tint="#383838"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Xếp hạng"
                        android:textSize="10sp"
                        android:textColor="#000000"
                        android:textStyle="bold"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/navProfile"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true">
                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:src="@drawable/ic_profile"
                        app:tint="#383838"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hồ sơ"
                        android:textSize="10sp"
                        android:textColor="#000000"
                        android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
