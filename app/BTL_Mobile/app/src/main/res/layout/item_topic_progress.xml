<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_soft_button"
    android:theme="@style/GrayButtonTheme"
    android:padding="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_soft_inner"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView
                android:id="@+id/txtTopicTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Đếm số 1-10"
                android:textColor="#333333"
                android:textStyle="bold"
                android:textSize="15sp"/>
            <TextView
                android:id="@+id/txtTopicInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3/5 bài"
                android:textColor="#888888"
                android:textSize="13sp"/>
        </LinearLayout>

        <ProgressBar
            android:id="@+id/topicProgressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:layout_marginTop="10dp"
            android:progress="60"
            android:progressDrawable="@android:drawable/progress_horizontal"
            android:progressTint="#4CAF50"
            android:progressBackgroundTint="#EEEEEE" />

    </LinearLayout>
</FrameLayout>