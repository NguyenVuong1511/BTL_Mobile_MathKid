<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- Header Section -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/gameHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_green_gardient"
        android:paddingHorizontal="20dp"
        android:paddingTop="48dp"
        android:paddingBottom="24dp"
        app:layout_constraintTop_toTopOf="parent">

        <FrameLayout
            android:id="@+id/btnExit"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_soft_button"
            android:theme="@style/GreenButtonTheme"
            android:padding="4dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_soft_inner">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_back"
                    app:tint="#FFFFFF"/>
            </FrameLayout>
        </FrameLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/txtScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ĐIỂM: 0"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtLives"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="❤️❤️❤️"
                android:textSize="18sp"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <ProgressBar
            android:id="@+id/timerProgressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="12dp"
            android:layout_marginTop="24dp"
            android:max="100"
            android:progress="100"
            android:progressDrawable="@android:drawable/progress_horizontal"
            android:progressTint="#FFD600"
            android:progressBackgroundTint="#4DFFFFFF"
            app:layout_constraintTop_toBottomOf="@id/btnExit" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Game Content Area -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/gameArea"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/gameHeader"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Problem Card -->
        <FrameLayout
            android:id="@+id/problemCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="32dp"
            android:background="@drawable/bg_soft_button"
            android:theme="@style/OrangeButtonTheme"
            android:padding="8dp"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_soft_inner"
                android:padding="40dp"
                android:gravity="center">

                <TextView
                    android:id="@+id/txtProblem"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="5 + 3 = ?"
                    android:textColor="#FFFFFF"
                    android:textSize="48sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </FrameLayout>

        <!-- Options Grid -->
        <GridLayout
            android:id="@+id/optionsGrid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:columnCount="2"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/problemCard"
            app:layout_constraintVertical_bias="0.3">

            <!-- Option 1 -->
            <FrameLayout
                android:id="@+id/btnOption1"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:background="@drawable/bg_soft_button"
                android:theme="@style/BlueButtonTheme"
                android:padding="6dp">
                <TextView
                    android:id="@+id/txtOption1"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_soft_inner"
                    android:gravity="center"
                    android:text="6"
                    android:textColor="#FFFFFF"
                    android:textSize="32sp"
                    android:textStyle="bold"/>
            </FrameLayout>

            <!-- Option 2 -->
            <FrameLayout
                android:id="@+id/btnOption2"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:background="@drawable/bg_soft_button"
                android:theme="@style/PurpleButtonTheme"
                android:padding="6dp">
                <TextView
                    android:id="@+id/txtOption2"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_soft_inner"
                    android:gravity="center"
                    android:text="7"
                    android:textColor="#FFFFFF"
                    android:textSize="32sp"
                    android:textStyle="bold"/>
            </FrameLayout>

            <!-- Option 3 -->
            <FrameLayout
                android:id="@+id/btnOption3"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:background="@drawable/bg_soft_button"
                android:theme="@style/PinkButtonTheme"
                android:padding="6dp">
                <TextView
                    android:id="@+id/txtOption3"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_soft_inner"
                    android:gravity="center"
                    android:text="8"
                    android:textColor="#FFFFFF"
                    android:textSize="32sp"
                    android:textStyle="bold"/>
            </FrameLayout>

            <!-- Option 4 -->
            <FrameLayout
                android:id="@+id/btnOption4"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:background="@drawable/bg_soft_button"
                android:theme="@style/GrayButtonTheme"
                android:padding="6dp">
                <TextView
                    android:id="@+id/txtOption4"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_soft_inner"
                    android:gravity="center"
                    android:text="9"
                    android:textColor="#333333"
                    android:textSize="32sp"
                    android:textStyle="bold"/>
            </FrameLayout>

        </GridLayout>

        <TextView
            android:id="@+id/txtHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:text="Chọn kết quả đúng thật nhanh nhé! ✨"
            android:textColor="#888888"
            android:textSize="14sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>