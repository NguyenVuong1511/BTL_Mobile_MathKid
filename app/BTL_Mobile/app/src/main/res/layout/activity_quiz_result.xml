<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFB"
    tools:context=".activities.QuizResult">

    <!-- Header với lời chúc -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/resultHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_green_gardient"
        android:paddingBottom="40dp"
        android:paddingTop="60dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/imgTrophy"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@drawable/ic_trophy"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/txtTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hoàn hảo! 🎉"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/imgTrophy"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/txtSub"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:paddingHorizontal="40dp"
            android:text="Bé làm đúng hết rồi! Bé là ngôi sao toán học."
            android:textSize="15sp"
            android:textColor="#E0F2F1"
            android:gravity="center"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/txtTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Sao đạt được - Soft UI Style -->
    <FrameLayout
        android:id="@+id/starContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="-30dp"
        android:background="@drawable/bg_soft_button"
        android:theme="@style/OrangeButtonTheme"
        android:padding="6dp"
        app:layout_constraintTop_toBottomOf="@id/resultHeader"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/layoutStars"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_soft_inner"
            android:orientation="horizontal"
            android:paddingHorizontal="24dp"
            android:paddingVertical="12dp">
            <ImageView android:layout_width="45dp" android:layout_height="45dp" android:src="@drawable/ic_star" />
            <ImageView android:layout_width="45dp" android:layout_height="45dp" android:src="@drawable/ic_star" android:layout_marginHorizontal="12dp"/>
            <ImageView android:layout_width="45dp" android:layout_height="45dp" android:src="@drawable/ic_star" />
        </LinearLayout>
    </FrameLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:clipToPadding="false"
        android:paddingBottom="40dp"
        app:layout_constraintTop_toBottomOf="@id/starContainer"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp">

            <!-- XP Earned Card -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_soft_button"
                android:theme="@style/OrangeButtonTheme"
                android:padding="4dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_soft_inner"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="20dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Điểm thưởng kiếm được"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:id="@+id/txtXPEarned"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+50 XP ⚡"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:textSize="32sp"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </FrameLayout>

            <!-- Stats Grid -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="20dp">

                <!-- Sao Item -->
                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_soft_button"
                    android:theme="@style/GrayButtonTheme"
                    android:padding="2dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_soft_inner"
                        android:gravity="center"
                        android:orientation="vertical">
                        <TextView android:id="@+id/txtResultStars" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="3/3" android:textColor="#333333" android:textSize="18sp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SỐ SAO" android:textColor="#888888" android:textSize="10sp" android:textStyle="bold"/>
                    </LinearLayout>
                </FrameLayout>

                <!-- Correct Item -->
                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="4dp"
                    android:background="@drawable/bg_soft_button"
                    android:theme="@style/GrayButtonTheme"
                    android:padding="2dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_soft_inner"
                        android:gravity="center"
                        android:orientation="vertical">
                        <TextView android:id="@+id/txtResultCorrect" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="5" android:textColor="#333333" android:textSize="18sp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CÂU ĐÚNG" android:textColor="#888888" android:textSize="10sp" android:textStyle="bold"/>
                    </LinearLayout>
                </FrameLayout>

                <!-- Streak Item -->
                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_soft_button"
                    android:theme="@style/GrayButtonTheme"
                    android:padding="2dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_soft_inner"
                        android:gravity="center"
                        android:orientation="vertical">
                        <TextView android:id="@+id/txtResultStreak" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="5 🔥" android:textColor="#333333" android:textSize="18sp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CHUỖI" android:textColor="#888888" android:textSize="10sp" android:textStyle="bold"/>
                    </LinearLayout>
                </FrameLayout>
            </LinearLayout>

            <!-- Action Buttons -->
            <FrameLayout
                android:id="@+id/btnNext"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:layout_marginTop="32dp"
                android:background="@drawable/bg_soft_button"
                android:theme="@style/GreenButtonTheme"
                android:padding="4dp">
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_soft_inner">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="🚀 Bài học tiếp theo"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </FrameLayout>
            </FrameLayout>

            <FrameLayout
                android:id="@+id/btnRetry"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_soft_button"
                android:theme="@style/GrayButtonTheme"
                android:padding="4dp">
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_soft_inner">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="🔄 Thử lại"
                        android:textColor="#333333"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </FrameLayout>
            </FrameLayout>

            <TextView
                android:id="@+id/txtHome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="40dp"
                android:text="🏠 Về trang chủ"
                android:textColor="#FF9800"
                android:textSize="16sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true"/>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
