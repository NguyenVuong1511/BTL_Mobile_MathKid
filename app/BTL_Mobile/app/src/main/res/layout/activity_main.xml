<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity"
    android:background="#FFFFFF">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomNavContainer">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp"
            android:background="#73DEDEDE">

            <!-- HEADER CARD -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp"
                android:paddingTop="40dp"
                android:background="@drawable/bg_green_gardient">

                <TextView
                    android:id="@+id/txtGreeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chào buổi sáng! 👋"
                    android:textColor="#E0E0E0"
                    android:textSize="14sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/txtName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Aiden"
                    android:textStyle="bold"
                    android:textSize="28sp"
                    android:textColor="#FFFFFF"
                    android:layout_marginTop="4dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/txtGreeting" />

                <LinearLayout
                    android:id="@+id/layoutTopRight"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="bottom"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="@id/txtName">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_xp_badge"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="6dp"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:layout_marginEnd="5dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⚡"
                            android:textSize="14sp"
                            android:layout_marginEnd="4dp"/>
                        <TextView
                            android:id="@+id/txtXPBadge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="350 XP"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold"
                            android:textSize="14sp"/>
                    </LinearLayout>

                    <ImageView
                        android:id="@+id/imgAvatar"
                        android:layout_width="70dp"
                        android:layout_height="70dp"
                        android:src="@drawable/fox"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/txtLevelProgress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tiến độ Cấp 3"
                    android:textColor="#E0E0E0"
                    android:textSize="13sp"
                    android:layout_marginTop="20dp"
                    app:layout_constraintTop_toBottomOf="@id/txtName"
                    app:layout_constraintStart_toStartOf="parent" />

                <TextView
                    android:id="@+id/txtXPValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="350/500 XP"
                    android:textColor="#B3FFFFFF"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    app:layout_constraintBottom_toBottomOf="@id/txtLevelProgress"
                    app:layout_constraintEnd_toEndOf="parent" />

                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="match_parent"
                    android:layout_height="12dp"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:progress="70"
                    android:progressDrawable="@android:drawable/progress_horizontal"
                    android:progressTint="#FFD600"
                    android:progressBackgroundTint="#4DFFFFFF"
                    android:layout_marginTop="8dp"
                    app:layout_constraintTop_toBottomOf="@id/txtLevelProgress"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- STREAK CARD -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFF9E6">
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/txtFireEmoji"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔥"
                        android:textSize="28sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"/>

                    <TextView
                        android:id="@+id/txtStreakTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Chuỗi 5 ngày!"
                        android:textColor="#FF8F00"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:layout_marginStart="16dp"
                        app:layout_constraintStart_toEndOf="@id/txtFireEmoji"
                        app:layout_constraintTop_toTopOf="parent"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Cố gắng lên! Luyện tập hôm nay để duy trì chuỗi của bạn"
                        android:textColor="#B28900"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp"
                        app:layout_constraintStart_toStartOf="@id/txtStreakTitle"
                        app:layout_constraintEnd_toStartOf="@id/imgNotify"
                        app:layout_constraintTop_toBottomOf="@id/txtStreakTitle"/>

                    <ImageView
                        android:id="@+id/imgNotify"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_popup_reminder"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:tint="#FF8F00" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bạn muốn làm gì? 🎯"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginStart="16dp"
                android:gravity="center"/>

            <!-- GRID OF ACTIONS -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:paddingHorizontal="8dp">

                <!-- Học Toán -->
                <FrameLayout
                    android:id="@+id/btnLearn"
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:background="@drawable/bg_soft_button"
                    android:theme="@style/GreenButtonTheme"
                    android:padding="10dp"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_soft_inner"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_book"
                            android:layout_marginBottom="8dp"/>

                        <TextView
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            android:text="Học Toán"
                            android:textColor="#F0FFF4"
                            android:textSize="16sp"
                            android:textStyle="bold"/>

                    </LinearLayout>

                </FrameLayout>

                <!-- Luyện tập -->
                <FrameLayout
                    android:id="@+id/btnPractice"
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:background="@drawable/bg_soft_button"
                    android:theme="@style/BlueButtonTheme"
                    android:padding="10dp"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_soft_inner"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_pencil"
                            android:layout_marginBottom="8dp"/>

                        <TextView
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            android:text="Luyện tập"
                            android:textColor="#F0F9FF"
                            android:textSize="16sp"
                            android:textStyle="bold"/>

                    </LinearLayout>

                </FrameLayout>

                <!-- Bài thi -->
                <FrameLayout
                    android:id="@+id/btnExam"
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:background="@drawable/bg_soft_button"
                    android:theme="@style/RedButtonTheme"
                    android:padding="10dp"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_soft_inner"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_star"
                            android:layout_marginBottom="8dp"/>

                        <TextView
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            android:text="Bài thi"
                            android:textColor="#FFF5F5"
                            android:textSize="16sp"
                            android:textStyle="bold"/>

                    </LinearLayout>

                </FrameLayout>

                <!-- Trò chơi Toán học -->
                <FrameLayout
                    android:id="@+id/btnGames"
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:background="@drawable/bg_soft_button"
                    android:theme="@style/PurpleButtonTheme"
                    android:padding="10dp"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_soft_inner"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_game"
                            android:layout_marginBottom="8dp"/>

                        <TextView
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            android:text="Trò chơi"
                            android:textColor="#FDF4FF"
                            android:textSize="16sp"
                            android:textStyle="bold"/>

                    </LinearLayout>

                </FrameLayout>

                <!-- Thành tích -->
                <FrameLayout
                    android:id="@+id/btnAchievements"
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:background="@drawable/bg_soft_button"
                    android:theme="@style/OrangeButtonTheme"
                    android:padding="10dp"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_soft_inner"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_trophy"
                            android:layout_marginBottom="8dp"/>

                        <TextView
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            android:text="Thành tích"
                            android:textColor="#FFFBF4"
                            android:textSize="16sp"
                            android:textStyle="bold"/>

                    </LinearLayout>

                </FrameLayout>

                <!-- Tiến độ của tôi -->
                <FrameLayout
                    android:id="@+id/btnProgress"
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:background="@drawable/bg_soft_button"
                    android:theme="@style/PinkButtonTheme"
                    android:padding="10dp"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_soft_inner"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_stat"
                            android:layout_marginBottom="8dp"/>

                        <TextView
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            android:text="Tiến độ"
                            android:textColor="#FFF4F8"
                            android:textSize="16sp"
                            android:textStyle="bold"/>

                    </LinearLayout>

                </FrameLayout>

            </GridLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Navigation Soft Style -->
    <FrameLayout
        android:id="@+id/bottomNavContainer"
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:paddingHorizontal="16dp"
        android:paddingBottom="10dp"
        android:background="#73DEDEDE"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/bottomNav"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:layout_gravity="bottom"
            android:background="@drawable/bg_soft_button"
            android:padding="6dp"
            android:orientation="horizontal"
            android:gravity="center">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_soft_inner"
                android:orientation="horizontal"
                android:gravity="center">

                <LinearLayout
                    android:id="@+id/navHome"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true">
                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:src="@drawable/ic_home"
                        app:tint="#4CAF50"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Trang chủ"
                        android:textSize="10sp"
                        android:textColor="#4CAF50"
                        android:textStyle="bold"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/navRanking"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true">
                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:src="@drawable/ic_cup"
                        app:tint="#888888"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Xếp hạng"
                        android:textSize="10sp"
                        android:textColor="#888888"
                        android:textStyle="bold"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/navProfile"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true">
                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:src="@drawable/ic_profile"
                        app:tint="#888888"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hồ sơ"
                        android:textSize="10sp"
                        android:textColor="#888888"
                        android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
