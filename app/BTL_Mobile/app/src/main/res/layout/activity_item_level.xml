<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".item_level"
    android:background="#F0F4F2">

    <!-- HEADER -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="48dp"
        android:paddingBottom="24dp"
        android:paddingHorizontal="24dp"
        android:background="@drawable/bg_green_gardient"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.cardview.widget.CardView
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            app:cardCornerRadius="14dp"
            app:cardBackgroundColor="#4DFFFFFF"
            app:cardElevation="0dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_back"
                app:tint="#FFFFFF" />
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:id="@+id/layoutTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginStart="16dp"
            app:layout_constraintStart_toEndOf="@id/btnBack"
            app:layout_constraintTop_toTopOf="parent">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lộ trình học tập"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold" />
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_book"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hoàn thành 3 trên 7 cấp độ"
            android:textColor="#CCFFFFFF"
            android:textSize="14sp"
            app:layout_constraintStart_toStartOf="@id/layoutTitle"
            app:layout_constraintTop_toBottomOf="@id/layoutTitle" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toTopOf="@id/bottomNav">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="40dp">

            <!-- Central Path Line -->
            <View
                android:id="@+id/pathLine"
                android:layout_width="4dp"
                android:layout_height="0dp"
                android:background="#D1E8D5"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- LEVEL 1 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardL1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="85dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">
                    <TextView android:id="@+id/lblL1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="LEVEL 1" android:textSize="12sp" android:textColor="#9E9E9E" android:textStyle="bold"/>
                    <TextView android:id="@+id/titleL1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_below="@id/lblL1" android:text="Số đếm 1-5" android:textSize="18sp" android:textColor="#333333" android:textStyle="bold" android:layout_marginTop="4dp"/>
                    <ImageView android:layout_width="32dp" android:layout_height="32dp" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:src="@drawable/ic_pencil" app:tint="#2196F3"/>
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_below="@id/titleL1" android:layout_marginTop="10dp">
                        <ImageView android:layout_width="18dp" android:layout_height="18dp" android:src="@drawable/ic_star"/>
                        <ImageView android:layout_width="18dp" android:layout_height="18dp" android:src="@drawable/ic_star" android:layout_marginStart="4dp"/>
                        <ImageView android:layout_width="18dp" android:layout_height="18dp" android:src="@drawable/ic_star" android:layout_marginStart="4dp"/>
                    </LinearLayout>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/nodeL1"
                android:layout_width="64dp"
                android:layout_height="64dp"
                app:cardCornerRadius="32dp"
                app:cardBackgroundColor="#4CAF50"
                app:cardElevation="6dp"
                app:layout_constraintTop_toTopOf="@id/cardL1"
                app:layout_constraintBottom_toBottomOf="@id/cardL1"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginEnd="16dp">
                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_check"
                    app:tint="#FFFFFF"
                    android:layout_gravity="center"/>
            </androidx.cardview.widget.CardView>

            <!-- LEVEL 2 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardL2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="50dp"
                android:layout_marginStart="85dp"
                android:layout_marginEnd="16dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp"
                app:layout_constraintTop_toBottomOf="@id/cardL1"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">
                    <TextView android:id="@+id/lblL2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="LEVEL 2" android:textSize="12sp" android:textColor="#9E9E9E" android:textStyle="bold"/>
                    <TextView android:id="@+id/titleL2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_below="@id/lblL2" android:text="Số đếm 6-10" android:textSize="18sp" android:textColor="#333333" android:textStyle="bold" android:layout_marginTop="4dp"/>
                    <ImageView android:layout_width="32dp" android:layout_height="32dp" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:src="@drawable/ic_pencil" app:tint="#2196F3"/>
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_below="@id/titleL2" android:layout_marginTop="10dp">
                        <ImageView android:layout_width="18dp" android:layout_height="18dp" android:src="@drawable/ic_star"/>
                        <ImageView android:layout_width="18dp" android:layout_height="18dp" android:src="@drawable/ic_star" android:layout_marginStart="4dp"/>
                        <ImageView android:layout_width="18dp" android:layout_height="18dp" android:src="@drawable/ic_star" android:layout_marginStart="4dp"/>
                    </LinearLayout>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/nodeL2"
                android:layout_width="64dp"
                android:layout_height="64dp"
                app:cardCornerRadius="32dp"
                app:cardBackgroundColor="#4CAF50"
                app:cardElevation="6dp"
                app:layout_constraintTop_toTopOf="@id/cardL2"
                app:layout_constraintBottom_toBottomOf="@id/cardL2"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginStart="16dp">
                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_check"
                    app:tint="#FFFFFF"
                    android:layout_gravity="center"/>
            </androidx.cardview.widget.CardView>

            <!-- LEVEL 3 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardL3"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="50dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="85dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp"
                app:layout_constraintTop_toBottomOf="@id/cardL2"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">
                    <TextView android:id="@+id/lblL3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="LEVEL 3" android:textSize="12sp" android:textColor="#9E9E9E" android:textStyle="bold"/>
                    <TextView android:id="@+id/titleL3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_below="@id/lblL3" android:text="Đếm vật thể" android:textSize="18sp" android:textColor="#333333" android:textStyle="bold" android:layout_marginTop="4dp"/>
                    <ImageView android:layout_width="32dp" android:layout_height="32dp" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:src="@drawable/cat"/>
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_below="@id/titleL3" android:layout_marginTop="10dp">
                        <ImageView android:layout_width="18dp" android:layout_height="18dp" android:src="@drawable/ic_star"/>
                        <ImageView android:layout_width="18dp" android:layout_height="18dp" android:src="@drawable/ic_star" android:layout_marginStart="4dp"/>
                        <ImageView android:layout_width="18dp" android:layout_height="18dp" android:src="@drawable/ic_star" android:layout_marginStart="4dp" android:alpha="0.3"/>
                    </LinearLayout>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/nodeL3"
                android:layout_width="64dp"
                android:layout_height="64dp"
                app:cardCornerRadius="32dp"
                app:cardBackgroundColor="#4CAF50"
                app:cardElevation="6dp"
                app:layout_constraintTop_toTopOf="@id/cardL3"
                app:layout_constraintBottom_toBottomOf="@id/cardL3"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginEnd="16dp">
                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_check"
                    app:tint="#FFFFFF"
                    android:layout_gravity="center"/>
            </androidx.cardview.widget.CardView>

            <!-- LEVEL 4 (ACTIVE) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardL4"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="50dp"
                android:layout_marginStart="85dp"
                android:layout_marginEnd="16dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="12dp"
                app:layout_constraintTop_toBottomOf="@id/cardL3"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">
                    <TextView android:id="@+id/lblL4" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="LEVEL 4" android:textSize="12sp" android:textColor="#9E9E9E" android:textStyle="bold"/>
                    <TextView android:id="@+id/titleL4" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_below="@id/lblL4" android:text="Phép cộng tới 5" android:textSize="18sp" android:textColor="#333333" android:textStyle="bold" android:layout_marginTop="4dp"/>
                    <ImageView android:layout_width="32dp" android:layout_height="32dp" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:src="@drawable/ic_pencil" app:tint="#FF9800"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/titleL4"
                        android:layout_marginTop="14dp"
                        android:text="▶ Bắt đầu ngay!"
                        android:textColor="#FF9800"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="8dp"
                        android:background="@drawable/bg_xp_badge"
                        android:backgroundTint="#FFF3E0"/>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/nodeL4"
                android:layout_width="74dp"
                android:layout_height="74dp"
                app:cardCornerRadius="37dp"
                app:cardBackgroundColor="#FF9800"
                app:cardElevation="10dp"
                app:layout_constraintTop_toTopOf="@id/cardL4"
                app:layout_constraintBottom_toBottomOf="@id/cardL4"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginStart="12dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="4" android:textColor="#FFFFFF" android:textSize="32sp" android:textStyle="bold" android:layout_gravity="center"/>
            </androidx.cardview.widget.CardView>

            <!-- LEVEL 5 (LOCKED) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardL5"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="50dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="85dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:layout_constraintTop_toBottomOf="@id/cardL4"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp"
                    android:alpha="0.4">
                    <TextView android:id="@+id/lblL5" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="LEVEL 5" android:textSize="12sp" android:textColor="#9E9E9E" android:textStyle="bold"/>
                    <TextView android:id="@+id/titleL5" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_below="@id/lblL5" android:text="Phép cộng tới 10" android:textSize="18sp" android:textColor="#333333" android:textStyle="bold" android:layout_marginTop="4dp"/>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/nodeL5"
                android:layout_width="64dp"
                android:layout_height="64dp"
                app:cardCornerRadius="32dp"
                app:cardBackgroundColor="#E0E0E0"
                app:cardElevation="2dp"
                app:layout_constraintTop_toTopOf="@id/cardL5"
                app:layout_constraintBottom_toBottomOf="@id/cardL5"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginEnd="16dp">
                <ImageView android:layout_width="28dp" android:layout_height="28dp" android:src="@android:drawable/ic_lock_idle_lock" android:layout_gravity="center" app:tint="#888888"/>
            </androidx.cardview.widget.CardView>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

    <!-- Bottom Navigation Mockup -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="#FFFFFF"
        android:elevation="16dp"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🏠" android:textSize="24sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Trang chủ" android:textSize="11sp" android:textColor="#888888"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📖" android:textSize="24sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Học tập" android:textSize="11sp" android:textColor="#4CAF50" android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🎮" android:textSize="24sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Trò chơi" android:textSize="11sp" android:textColor="#888888"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="👤" android:textSize="24sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Hồ sơ" android:textSize="11sp" android:textColor="#888888"/>
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
