<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFB">

    <!-- Header với Progress phong cách Soft UI -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/quizHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_green_gardient"
        android:paddingHorizontal="20dp"
        android:paddingTop="40dp"
        android:paddingBottom="24dp"
        app:layout_constraintTop_toTopOf="parent">

        <FrameLayout
            android:id="@+id/btnExit"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:background="@drawable/bg_soft_button"
            android:theme="@style/GreenButtonTheme"
            android:padding="4dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_soft_inner">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_back"
                    app:tint="#FFFFFF" />
            </FrameLayout>
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="16dp"
            app:layout_constraintBottom_toBottomOf="@id/btnExit"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/btnExit"
            app:layout_constraintTop_toTopOf="@id/btnExit">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Tiến độ bài học"
                    android:textColor="#E0F2F1"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtQuestionIndex"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1/1"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="14sp" />
            </LinearLayout>

            <ProgressBar
                android:id="@+id/quizProgressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="10dp"
                android:progress="30"
                android:progressDrawable="@android:drawable/progress_horizontal"
                android:progressTint="#FFD600"
                android:progressBackgroundTint="#4DFFFFFF" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Thẻ câu hỏi Soft UI -->
    <FrameLayout
        android:id="@+id/questionCard"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_margin="24dp"
        android:background="@drawable/bg_soft_button"
        android:padding="8dp"
        android:theme="@style/GreenButtonTheme"
        app:layout_constraintBottom_toTopOf="@+id/containerContent"
        app:layout_constraintTop_toBottomOf="@id/quizHeader">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_soft_inner"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp">

            <ImageView
                android:id="@+id/imgQuestion"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginBottom="16dp"
                android:scaleType="centerInside"
                android:visibility="visible" />

            <TextView
                android:id="@+id/txtQuestionText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Bé hãy chọn đáp án đúng?"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />

            <FrameLayout
                android:id="@+id/dropZone"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_form"
                android:visibility="gone">
                <TextView
                    android:id="@+id/txtDroppedValue"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="?"
                    android:textColor="#FFFFFF"
                    android:textSize="32sp"
                    android:textStyle="bold" />
            </FrameLayout>
        </LinearLayout>
    </FrameLayout>

    <!-- Container cho các loại nội dung -->
    <FrameLayout
        android:id="@+id/containerContent"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginBottom="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/questionCard">

        <GridLayout
            android:id="@+id/optionsGrid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:columnCount="2"
            android:rowCount="2"
            android:visibility="gone">
            <FrameLayout android:id="@+id/option1" android:layout_width="0dp" android:layout_height="90dp" android:layout_columnWeight="1" android:layout_margin="8dp" android:background="@drawable/bg_soft_button" android:padding="4dp" android:theme="@style/BlueButtonTheme"><TextView android:layout_width="match_parent" android:layout_height="match_parent" android:background="@drawable/bg_soft_inner" android:gravity="center" android:textColor="#FFFFFF" android:textSize="24sp" android:textStyle="bold" /></FrameLayout>
            <FrameLayout android:id="@+id/option2" android:layout_width="0dp" android:layout_height="90dp" android:layout_columnWeight="1" android:layout_margin="8dp" android:background="@drawable/bg_soft_button" android:padding="4dp" android:theme="@style/PinkButtonTheme"><TextView android:layout_width="match_parent" android:layout_height="match_parent" android:background="@drawable/bg_soft_inner" android:gravity="center" android:textColor="#FFFFFF" android:textSize="24sp" android:textStyle="bold" /></FrameLayout>
            <FrameLayout android:id="@+id/option3" android:layout_width="0dp" android:layout_height="90dp" android:layout_columnWeight="1" android:layout_margin="8dp" android:background="@drawable/bg_soft_button" android:padding="4dp" android:theme="@style/OrangeButtonTheme"><TextView android:layout_width="match_parent" android:layout_height="match_parent" android:background="@drawable/bg_soft_inner" android:gravity="center" android:textColor="#FFFFFF" android:textSize="24sp" android:textStyle="bold" /></FrameLayout>
            <FrameLayout android:id="@+id/option4" android:layout_width="0dp" android:layout_height="90dp" android:layout_columnWeight="1" android:layout_margin="8dp" android:background="@drawable/bg_soft_button" android:padding="4dp" android:theme="@style/PurpleButtonTheme"><TextView android:layout_width="match_parent" android:layout_height="match_parent" android:background="@drawable/bg_soft_inner" android:gravity="center" android:textColor="#FFFFFF" android:textSize="24sp" android:textStyle="bold" /></FrameLayout>
        </GridLayout>

        <LinearLayout android:id="@+id/dragContainer" android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:orientation="horizontal" android:padding="10dp" android:visibility="gone" />

        <ScrollView android:id="@+id/matchingContainer" android:layout_width="match_parent" android:layout_height="match_parent" android:visibility="gone">
            <LinearLayout android:id="@+id/layoutMatchingPairs" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:paddingHorizontal="16dp" />
        </ScrollView>

        <LinearLayout android:id="@+id/comparisonContainer" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:orientation="vertical" android:visibility="gone">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:orientation="horizontal">
                <FrameLayout android:layout_width="100dp" android:layout_height="100dp" android:background="@drawable/bg_soft_button" android:theme="@style/BlueButtonTheme" android:padding="4dp"><TextView android:id="@+id/txtCompareLeft" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@drawable/bg_soft_inner" android:gravity="center" android:textColor="#FFFFFF" android:textSize="32sp" android:textStyle="bold" /></FrameLayout>
                <FrameLayout android:id="@+id/dropZoneCompare" android:layout_width="80dp" android:layout_height="80dp" android:layout_marginHorizontal="20dp" android:background="@drawable/bg_form"><TextView android:id="@+id/txtDroppedCompare" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:text="?" android:textColor="#FFFFFF" android:textSize="32sp" android:textStyle="bold" /></FrameLayout>
                <FrameLayout android:id="@+id/dropZoneCompareRight" android:layout_width="100dp" android:layout_height="100dp" android:background="@drawable/bg_soft_button" android:theme="@style/PinkButtonTheme" android:padding="4dp"><TextView android:id="@+id/txtCompareRight" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@drawable/bg_soft_inner" android:gravity="center" android:textColor="#FFFFFF" android:textSize="32sp" android:textStyle="bold" /></FrameLayout>
            </LinearLayout>
            <LinearLayout android:id="@+id/compareDragArea" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="40dp" android:gravity="center" android:orientation="horizontal" />
        </LinearLayout>
    </FrameLayout>
</androidx.constraintlayout.widget.ConstraintLayout>