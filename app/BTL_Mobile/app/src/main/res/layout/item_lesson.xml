<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingVertical="12dp">

    <!-- Central Path Line -->
    <View
        android:id="@+id/pathLine"
        android:layout_width="6dp"
        android:layout_height="0dp"
        android:background="#E8F5E9"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- LEFT LAYOUT -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutLeft"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Card Container using FrameLayout with bg_soft_button style -->
        <FrameLayout
            android:id="@+id/cardLeft"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="90dp"
            android:background="@drawable/bg_soft_button"
            android:padding="8dp"
            android:theme="@style/GreenButtonTheme"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_soft_inner"
                android:orientation="vertical"
                android:padding="12dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <TextView android:id="@+id/txtLevelLeft" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="LEVEL 1" android:textSize="11sp" android:textColor="#E0F2F1" android:textStyle="bold"/>
                        <TextView android:id="@+id/txtTitleLeft" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Title" android:textSize="17sp" android:textColor="#FFFFFF" android:textStyle="bold" android:layout_marginTop="2dp"/>
                    </LinearLayout>
                    <ImageView android:id="@+id/imgIconLeft" android:layout_width="32dp" android:layout_height="32dp" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:src="@drawable/ic_pencil" app:tint="#FFFFFF"/>
                </RelativeLayout>

                <LinearLayout android:id="@+id/starsLeft" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp">
                    <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_star" app:tint="#FFD600"/>
                    <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_star" android:layout_marginStart="4dp" app:tint="#FFD600"/>
                    <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_star" android:layout_marginStart="4dp" app:tint="#4DFFFFFF"/>
                </LinearLayout>

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnStartLeft"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_button_orange_light"
                    android:text="▶ Start Now!"
                    android:textAllCaps="false"
                    android:textColor="#F57C00"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="16dp"
                    android:visibility="gone"/>
            </LinearLayout>
        </FrameLayout>

        <!-- Node with soft style -->
        <FrameLayout
            android:id="@+id/nodeLeft"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/bg_soft_button"
            android:padding="6dp"
            android:theme="@style/GreenButtonTheme"
            app:layout_constraintTop_toTopOf="@id/cardLeft"
            app:layout_constraintBottom_toBottomOf="@id/cardLeft"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginEnd="12dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_soft_inner">
                <TextView android:id="@+id/txtNodeNumLeft" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="1" android:textColor="#FFFFFF" android:textSize="20sp" android:textStyle="bold" android:visibility="gone"/>
                <ImageView android:id="@+id/imgStatusLeft" android:layout_width="24dp" android:layout_height="24dp" android:layout_gravity="center" android:src="@drawable/ic_check" app:tint="#FFFFFF"/>
            </FrameLayout>
        </FrameLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- RIGHT LAYOUT -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutRight"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        android:visibility="gone">

        <FrameLayout
            android:id="@+id/cardRight"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="90dp"
            android:layout_marginEnd="20dp"
            android:background="@drawable/bg_soft_button"
            android:padding="8dp"
            android:theme="@style/BlueButtonTheme"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_soft_inner"
                android:orientation="vertical"
                android:padding="12dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <TextView android:id="@+id/txtLevelRight" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="LEVEL 2" android:textSize="11sp" android:textColor="#E1F5FE" android:textStyle="bold"/>
                        <TextView android:id="@+id/txtTitleRight" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Title" android:textSize="17sp" android:textColor="#FFFFFF" android:textStyle="bold" android:layout_marginTop="2dp"/>
                    </LinearLayout>
                    <ImageView android:id="@+id/imgIconRight" android:layout_width="32dp" android:layout_height="32dp" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:src="@drawable/ic_pencil" app:tint="#FFFFFF"/>
                </RelativeLayout>

                <LinearLayout android:id="@+id/starsRight" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp">
                    <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_star" app:tint="#FFD600"/>
                    <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_star" android:layout_marginStart="4dp" app:tint="#FFD600"/>
                    <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_star" android:layout_marginStart="4dp" app:tint="#4DFFFFFF"/>
                </LinearLayout>

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnStartRight"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_button_orange_light"
                    android:text="▶ Start Now!"
                    android:textAllCaps="false"
                    android:textColor="#F57C00"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="16dp"
                    android:visibility="gone"/>
            </LinearLayout>
        </FrameLayout>

        <FrameLayout
            android:id="@+id/nodeRight"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/bg_soft_button"
            android:padding="6dp"
            android:theme="@style/BlueButtonTheme"
            app:layout_constraintTop_toTopOf="@id/cardRight"
            app:layout_constraintBottom_toBottomOf="@id/cardRight"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginStart="12dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_soft_inner">
                <TextView android:id="@+id/txtNodeNumRight" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="2" android:textColor="#FFFFFF" android:textSize="20sp" android:textStyle="bold" android:visibility="gone"/>
                <ImageView android:id="@+id/imgStatusRight" android:layout_width="24dp" android:layout_height="24dp" android:layout_gravity="center" android:src="@drawable/ic_check" app:tint="#FFFFFF"/>
            </FrameLayout>
        </FrameLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
